{
  "extends": ["prettier", "plugin:react/recommended"],
  "parser": "babel-eslint",
  "parserOptions": {
    "ecmaVersion": 8,
    "jsx": true
  },
  "plugins": ["prettier", "react"],
  "rules": {
    "arrow-body-style": 0,
    "no-unused-expressions": 0,
    "max-nested-callbacks": 0,
    "no-invalid-this": 0,
    "import/no-named-as-default": 0,
    "prettier/prettier": ["error", {
      "singleQuote": true,
      "trailingComma": true,
      "bracketSpacing": false,
      "jsxBracketSameLine": false
    }]
  },
  "globals": {
    "describe": true,
    "it": true,
    "fetch": true,
    "snapshotRenderer": true,
    "shallow": true,
    "beforeEach": true,
    "React": true,
    "expect": true,
    "mount": true,
    "window": true,
    "jest": true,
    "setImmediate": true
  }
}
